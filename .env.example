# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/whatsapp-bot

# API Keys (Keep these secure!)
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gen_ai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# API Authentication (Basic Auth)
API_USERNAME=admin
API_PASSWORD=admin123

# Environment
NODE_ENV=development

# AI Provider Routing
AI_PROVIDER=google
AI_MODEL_GROQ="openai/gpt-oss-120b"
AI_MODEL_GOOGLE="gemma-4-31b-it"
AI_MULTIMODAL_MODEL_GOOGLE="gemma-4-31b-it"

# Vector Database (Qdrant) + Embeddings
QDRANT_URL="https://your-qdrant-instance.cloud.qdrant.io"
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION="ai_knowledge"
AI_EMBEDDING_MODEL_GOOGLE="gemini-embedding-2-preview"
AI_VECTOR_TOP_K=5
AI_VECTOR_MIN_SCORE=0.45
